        function atualizarHistFat(val) { rbt12Value = pM(mascara(val)); document.getElementById('rbt12Ini').value = mascara(val); recalc(); }
        function atualizarHistFolha(val) { folha12Value = pM(mascara(val)); document.getElementById('folha12Ini').value = mascara(val); recalc(); }
        function atualizarDado(idx, campo, strVal) { dados[idx][campo] = pM(mascara(strVal)); document.getElementById(`in_${idx}_${campo}`).value = mascara(strVal); recalc(); }

        function recalc() {
            if(anexosSel.length === 0) return;
            let histFat = []; let histFolha = [];
            const usaFolha = anexosSel.some(a => a.startsWith('5') || a.startsWith('3'));
            let chavesAnexos = Object.keys(NOMES_ANEXOS);

            dados.forEach((mes, idx) => {
                let totalFatMes = 0;
                chavesAnexos.forEach(k => totalFatMes += (mes['v'+k]||0));
                
                let rbt12 = 0, folha12 = 0;

                if (idx === 0) {
                    rbt12 = (precisaHistorico && rbt12Value > 0) ? rbt12Value : totalFatMes * 12;
                    folha12 = (precisaHistorico && folha12Value > 0) ? folha12Value : (mes.folha||0) * 12;
                } else {
                    let acumFat = histFat.reduce((a,b)=>a+b,0); let acumFolha = histFolha.reduce((a,b)=>a+b,0);
                    if (precisaHistorico && rbt12Value > 0) {
                        let mRest = Math.max(12 - idx, 0);
                        rbt12 = acumFat + ((rbt12Value / 12) * mRest); folha12 = acumFolha + ((folha12Value / 12) * mRest);
                    } else {
                        rbt12 = idx >= 12 ? histFat.slice(-12).reduce((a,b)=>a+b,0) : (acumFat / idx) * 12;
                        folha12 = idx >= 12 ? histFolha.slice(-12).reduce((a,b)=>a+b,0) : (acumFolha / idx) * 12;
                    }
                }

                let fatorR = rbt12 > 0 ? (folha12 / rbt12) : 0;
                let fx = getFaixa(rbt12);

                document.getElementById(`out_${idx}_rbt12`).innerHTML = `<span class="text-white">${rbt12.toLocaleString('pt-BR',{minimumFractionDigits:2, maximumFractionDigits:2})}</span><br><span class="text-[10px] text-gray-500 font-bold">Faixa ${fx.n} <span class="font-normal text-[9px]">(${fx.t})</span></span>`;

                if(usaFolha) {
                    const elFatorR = document.getElementById(`out_${idx}_fatorR`);
                    let detalheR = rbt12 > 0 ? `${folha12.toLocaleString('pt-BR',{maximumFractionDigits:0})} /<br>${rbt12.toLocaleString('pt-BR',{maximumFractionDigits:0})}` : '0 /<br>0';
                    elFatorR.innerHTML = `${(fatorR*100).toFixed(1)}% <div class="text-[9px] text-gray-500 font-normal leading-tight mt-1 pt-1 border-t border-[#1e2a3a]">${detalheR}</div>`;
                    elFatorR.className = `text-center font-bold bg-[#121c2a] text-[13px] ${fatorR >= 0.28 ? 'text-green-500' : 'text-red-400'}`;
                }

                const calc = calcularPeriodoDetalhado(mes, rbt12, fatorR);
                document.getElementById(`out_${idx}_tot`).innerText = calc.total.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                document.getElementById(`out_${idx}_efetiva`).innerText = totalFatMes > 0 ? (calc.total/totalFatMes*100).toFixed(2) + '% Efetiva' : '0,00% Efetiva';

                let detHtml = `<div class="flex flex-wrap gap-4">`;
                anexosSel.forEach(anexId => {
                    if(mes['v'+anexId] > 0 && calc.porAnexo[anexId]) {
                        const anexoObj = calc.porAnexo[anexId];
                        let somaEfetivasFracoes = 0; 

                        let impostosHtml = Object.entries(anexoObj.det).map(([imp, v]) => {
                            if(!v.isento) somaEfetivasFracoes += v.efetiva;
                            let badge = v.tag || "RETIDO / POR FORA";
                            return `
                            <div class="bg-[#1e1e20] p-3 rounded border border-[#333336] flex flex-col justify-center ${v.isento ? 'opacity-60' : ''}">
                                <span class="text-[11px] font-black text-gray-400 uppercase tracking-wider">${imp}</span>
                                <div class="font-bold text-sm text-white mt-1 ${v.isento ? 'line-through text-gray-500' : ''}">
                                    ${v.val.toLocaleString('pt-BR',{minimumFractionDigits:2, maximumFractionDigits:2})} 
                                    <span class="${v.isento ? 'text-gray-500' : 'text-maradel'} text-[10px] ml-1">(${(v.efetiva*100).toFixed(2)}%)</span>
                                </div>
                                ${v.isento ? `<span class="text-[9px] ${v.tag === 'ISENTO (EXP)' ? 'text-green-500' : (v.tag === 'ABATIDO (PERS.)' ? 'text-blue-400' : 'text-red-400')} font-bold mt-1 tracking-tight">${badge}</span>` : ''}
                            </div>`;
                        }).join('');

                        let difProvaReal = Math.abs(somaEfetivasFracoes - anexoObj.aliqEfetiva);
                        let alertaProvaReal = difProvaReal > 0.0001 ? 
                            `<span class="text-red-400 ml-1">⚠️ Erro na Tabela: A soma difere da Alíquota Cobrada!</span>` : 
                            `<span class="text-green-400 ml-1">✓ Cálculo Validado</span>`;

                        detHtml += `
                            <div class="bg-[#18181b] p-4 rounded-xl shadow border-l-[6px] border-maradel border-t border-r border-b border-[#333336] flex-1 min-w-[280px]">
                                <div class="flex justify-between items-center mb-4 border-b border-[#333336] pb-3">
                                    <h4 class="font-black text-white text-lg tracking-tight">${NOMES_ANEXOS[anexId]} <span class="text-[11px] text-gray-500 font-normal ml-1">(${anexoObj.alertaFatorR?'Fator R aplicado':''})</span></h4>
                                    <div class="text-right">
                                        <div class="font-black text-xl text-maradel">${anexoObj.total.toLocaleString('pt-BR',{minimumFractionDigits:2, maximumFractionDigits:2})}</div>
                                        <div class="text-xs text-gray-400 font-bold">${(anexoObj.aliqEfetiva*100).toFixed(2)}% Cobrada</div>
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-2 text-center">
                                    ${impostosHtml}
                                </div>
                                <div class="text-[10px] text-gray-500 font-bold mt-4 pt-2 border-t border-[#333336] flex justify-between">
                                    <span>Soma Frações: ${(somaEfetivasFracoes*100).toFixed(2)}%</span>
                                    <span>${alertaProvaReal}</span>
                                </div>
                            </div>
                        `;
                    }
                });
                
                if(anexosSel.some(a => a.startsWith('5'))) {
                    let metaFolha = rbt12 * 0.28;
                    let metaFat = folha12 > 0 ? (folha12 / 0.28) : 0;
                    detHtml += `<div class="w-full mt-2 p-4 bg-[#121c2a] border border-[#1e2a3a] rounded text-sm text-blue-300">
                        <span class="font-bold uppercase tracking-wider text-[10px] block mb-2 text-blue-400">Metas Fator R (28%) para Anexo V</span>
                        Para atingir o Fator R nesta competência (RBT12 base: R$ ${rbt12.toLocaleString('pt-BR',{minimumFractionDigits:2})}), você precisaria de:<br>
                        ➜ Folha 12m mínima de: <b class="text-white">R$ ${metaFolha.toLocaleString('pt-BR',{minimumFractionDigits:2})}</b> <br>
                        ➜ Ou Faturamento 12m máximo de: <b class="text-white">R$ ${metaFat.toLocaleString('pt-BR',{minimumFractionDigits:2})}</b>
                    </div>`;
                }

                if(calc.total === 0) detHtml += `<div class="text-gray-500 text-sm font-bold w-full text-center py-4">Nenhum imposto calculado para esta competência.</div>`;
                detHtml += `</div>`;
                document.getElementById(`det_${idx}`).innerHTML = detHtml;

                histFat.push(totalFatMes);
                histFolha.push(mes.folha||0);
            });
        }

        function toggleExp(idx) {
            const btn = event.target;
            const tr = document.getElementById(`tr_exp_${idx}`);
            dados[idx].exp = !dados[idx].exp;
            if(dados[idx].exp) { tr.classList.remove('hidden'); btn.innerText = '-'; } 
            else { tr.classList.add('hidden'); btn.innerText = '+'; }
        }
        
        function aplicarParaBaixo(idx) { idxAplicarPendente = idx; document.getElementById('modalConfirmAplicar').classList.remove('hidden'); }
        function fecharModalAplicar() { idxAplicarPendente = null; document.getElementById('modalConfirmAplicar').classList.add('hidden'); }

        function confirmarAplicarParaBaixo() {
            const r = dados[idxAplicarPendente];
            for(let i=idxAplicarPendente+1; i<dados.length; i++){
                anexosSel.forEach(a => { dados[i]['v'+a] = r['v'+a]; document.getElementById(`in_${i}_v${a}`).value = mascara(r['v'+a].toFixed(2)); });
                if(anexosSel.some(a => a.startsWith('5') || a.startsWith('3'))) { dados[i].folha = r.folha; document.getElementById(`in_${i}_folha`).value = mascara(r.folha.toFixed(2)); }
            }
            recalc(); fecharModalAplicar();
        }

        function calcularPeriodoDetalhado(mes, rbt12, fatorR) {
            let res = { total: 0, porAnexo: {} };
            anexosSel.forEach(anexoId => {
                const fatAnexo = mes['v'+anexoId] || 0;
                if(fatAnexo > 0) {
                    let baseId = parseInt(anexoId.split('_')[0]);
                    let variant = anexoId.split('_')[1];
                    let tabelaUsadaId = baseId;
                    let alertaFatorR = false;

                    if (baseId === 5 && fatorR >= 0.28) { tabelaUsadaId = 3; alertaFatorR = true; }

                    const faixas = TABELAS[tabelaUsadaId];
                    const f = faixas.find(fx => rbt12 <= fx.ate) || faixas[faixas.length-1];
                    let aliqEf = rbt12 <= 0 ? f.aliq : ((rbt12 * f.aliq) - f.ded) / rbt12;
                    let aliqEfetivaFinal = Math.max(aliqEf, 0);
                    
                    let detImpostos = {}; let vImpostoAnexoTotal = 0; let aliqEfetivaCobrada = 0;
                    
                    let configPers = abatimentosPers[anexoId] || {};
                    let deduzirMonoCheckbox = false;
                    
                    if(anexoId === '1_ST') deduzirMonoCheckbox = document.getElementById('chkAnexo1_ST_Mono')?.checked;
                    if(anexoId === '2_ST') deduzirMonoCheckbox = document.getElementById('chkAnexo2_ST_Mono')?.checked;

                    Object.entries(f.part).forEach(([k,p]) => {
                        if (p > 0) {
                            let isento = false;
                            let tag = "";

                            if (variant === 'EXP' && (k === 'Pis' || k === 'Cofins' || k === 'ISS' || k === 'ICMS' || k === 'IPI')) {
                                isento = true; tag = "ISENTO (EXP)";
                            } else if (variant === 'RET' && (k === 'ISS' || k === 'ICMS')) {
                                isento = true; tag = "RETIDO";
                            } else if (variant === 'ST') {
                                if (k === 'ICMS' || k === 'IPI') {
                                    isento = true; tag = "ST";
                                } else if ((k === 'Pis' || k === 'Cofins') && deduzirMonoCheckbox) {
                                    isento = true; tag = "MONOFÁSICO";
                                }
                            } else if (variant === 'PERS') {
                                let matchK = k === 'ISS' ? 'ISS' : (k === 'ICMS' ? 'ICMS' : k);
                                if (configPers[matchK]) { isento = true; tag = "ABATIDO (PERS.)"; }
                            }

                            const valImposto = (fatAnexo * aliqEfetivaFinal)*p;
                            const efetivaImposto = aliqEfetivaFinal*p;

                            detImpostos[k] = { val: valImposto, efetiva: efetivaImposto, isento: isento, tag: tag };
                            
                            if (!isento) {
                                vImpostoAnexoTotal += valImposto;
                                aliqEfetivaCobrada += efetivaImposto;
                            }
                        }
                    });
                    res.total += vImpostoAnexoTotal;
                    res.porAnexo[anexoId] = { total: vImpostoAnexoTotal, aliqEfetiva: aliqEfetivaCobrada, det: detImpostos, alertaFatorR: alertaFatorR };
                }
            });
            return res;
        }

        function exportarExcel() {
            if(dados.length === 0 || anexosSel.length === 0) { alert("Preencha dados na simulação."); return; }
            let dataArr = [];
            let header = ["Mês/Ano", "RBT12", "Faixa"];
            anexosSel.forEach(a => header.push(NOMES_ANEXOS[a]));
            if(anexosSel.some(a => a.startsWith('5') || a.startsWith('3'))) header.push("Folha Salarial", "Fator R (%)");
            header.push("Total Faturamento", "DAS Total", "Alíquota Efetiva Global (%)");
            
            anexosSel.forEach(a => {
                header.push(`Aliq. Ef. ${NOMES_ANEXOS[a]}`, `Imposto ${NOMES_ANEXOS[a]}`, `IRPJ ${NOMES_ANEXOS[a]}`, `CSLL ${NOMES_ANEXOS[a]}`, `Cofins ${NOMES_ANEXOS[a]}`, `PIS ${NOMES_ANEXOS[a]}`, `CPP ${NOMES_ANEXOS[a]}`);
                if(a.startsWith('2')) header.push(`IPI ${NOMES_ANEXOS[a]}`);
                header.push(`ISS / ICMS ${NOMES_ANEXOS[a]}`);
            });
            dataArr.push(header);

            let histFat = []; let histFolha = [];
            let chavesAnexos = Object.keys(NOMES_ANEXOS);

            dados.forEach((mes, idx) => {
                let totalFatMes = 0;
                chavesAnexos.forEach(k => totalFatMes += (mes['v'+k]||0));
                
                let rbt12 = 0, folha12 = 0;
                if (idx === 0) {
                    rbt12 = (precisaHistorico && rbt12Value > 0) ? rbt12Value : totalFatMes * 12;
                    folha12 = (precisaHistorico && folha12Value > 0) ? folha12Value : (mes.folha||0) * 12;
                } else {
                    let acumFat = histFat.reduce((a,b)=>a+b,0); let acumFolha = histFolha.reduce((a,b)=>a+b,0);
                    if (precisaHistorico && rbt12Value > 0) {
                        let mRest = Math.max(12 - idx, 0);
                        rbt12 = acumFat + ((rbt12Value / 12) * mRest); folha12 = acumFolha + ((folha12Value / 12) * mRest);
                    } else {
                        rbt12 = idx >= 12 ? histFat.slice(-12).reduce((a,b)=>a+b,0) : (acumFat / idx) * 12;
                        folha12 = idx >= 12 ? histFolha.slice(-12).reduce((a,b)=>a+b,0) : (acumFolha / idx) * 12;
                    }
                }
                
                let fatorR = rbt12 > 0 ? (folha12 / rbt12) : 0;
                let fx = getFaixa(rbt12);
                const calc = calcularPeriodoDetalhado(mes, rbt12, fatorR);
                histFat.push(totalFatMes); histFolha.push(mes.folha||0);

                let row = [mes.mes, rbt12, `Faixa ${fx.n}`];
                anexosSel.forEach(a => row.push(mes['v'+a]||0));
                if(anexosSel.some(a => a.startsWith('5') || a.startsWith('3'))) row.push(mes.folha||0, fatorR);
                row.push(totalFatMes, calc.total, totalFatMes > 0 ? (calc.total/totalFatMes) : 0);

                anexosSel.forEach(a => {
                    const obj = calc.porAnexo[a] || { aliqEfetiva:0, total:0, det:{} };
                    row.push(obj.aliqEfetiva, obj.total, obj.det.IRPJ?.val||0, obj.det.CSLL?.val||0, obj.det.Cofins?.val||0, obj.det.Pis?.val||0, obj.det.CPP?.val||0);
                    if(a.startsWith('2')) row.push(obj.det.IPI?.val||0);
                    row.push(obj.det.ISS?.val || obj.det.ICMS?.val || 0);
                });
                dataArr.push(row);
            });

            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.aoa_to_sheet(dataArr);
            XLSX.utils.book_append_sheet(wb, ws, "Simulação");
            XLSX.writeFile(wb, "Simulacao_Maradel.xlsx");
        }

        function aba(t) {
            document.getElementById('cSim').classList.toggle('hidden', t!=='sim');
            document.getElementById('cRef').classList.toggle('hidden', t!=='ref');
            document.getElementById('aSim').classList.toggle('tab-active', t==='sim');
            document.getElementById('aSim').classList.toggle('text-gray-500', t!=='sim');
            document.getElementById('aRef').classList.toggle('tab-active', t==='ref');
            document.getElementById('aRef').classList.toggle('text-gray-500', t!=='ref');
            if(t==='ref') renderRef();
        }

        function renderRef() {
            const area = document.getElementById('tabelasArea');
            area.innerHTML = "";
            const headers = { 1: "ANEXO I - COMÉRCIO", 2: "ANEXO II - INDÚSTRIA", 3: "ANEXO III - SERVIÇOS", 4: "ANEXO IV - OBRAS / ESPECÍFICOS", 5: "ANEXO V - SERVIÇOS" };
            const tribs = ['IRPJ', 'CSLL', 'Cofins', 'Pis', 'CPP', 'ICMS', 'ISS', 'IPI'];

            [1,2,3,4,5].forEach(i => {
                area.innerHTML += `
                    <div class="mb-10">
                        <h3 class="font-black text-xl text-maradel mb-3">${headers[i]}</h3>
                        <div class="rounded border border-[#333336] shadow-sm">
                            <table class="w-full ref-table">
                                <thead>
                                    <tr>
                                        <th class="w-16">Faixa</th><th class="w-40">Receita 12m</th><th class="w-20">Alíquota</th><th class="w-24">Dedução</th>
                                        ${tribs.map(t => `<th class="w-14">${t}</th>`).join('')}
                                    </tr>
                                </thead>
                                <tbody>
                                    ${TABELAS[i].map((f, idx) => `
                                        <tr>
                                            <td class="font-bold text-white">${idx+1}ª</td>
                                            <td>Até ${f.ate.toLocaleString('pt-BR',{minimumFractionDigits:2})}</td>
                                            <td class="font-bold text-white">${(f.aliq*100).toFixed(2)}%</td>
                                            <td>${f.ded.toLocaleString('pt-BR',{minimumFractionDigits:2})}</td>
                                            ${tribs.map(t => `<td>${f.part[t] ? (f.part[t]*100).toFixed(2)+'%' : '-'}</td>`).join('')}
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;
            });
        }
    </script>
