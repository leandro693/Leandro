                        </div>
                    </td>
                </tr>`;
            }

            if(anexosSel.length === 0) {
                html += `<tr><td colspan="3" class="text-center py-10 text-gray-500 font-bold">Por favor, selecione pelo menos um anexo no painel acima.</td></tr>`;
                document.getElementById('corpo').innerHTML = html;
                return;
            }

            dados.forEach((mes, idx) => {
                html += `<tr class="hover:bg-[#27272a] transition-colors border-b border-[#333336]">`;
                html += `<td class="font-bold text-gray-300 bg-[#1e1e20] text-center text-sm">${mes.mes}</td>`;
                
                html += `<td class="bg-[#18181b] text-right pr-3 leading-tight" id="out_${idx}_rbt12"></td>`;

                anexosSel.forEach(a => {
                    html += `<td><input type="text" id="in_${idx}_v${a}" value="${mes['v'+a]?mascara(mes['v'+a].toFixed(2)):''}" oninput="atualizarDado(${idx}, 'v${a}', this.value)"></td>`;
                });

                if(usaFolha) {
                    html += `<td class="bg-[#121c2a]"><input type="text" id="in_${idx}_folha" value="${mes.folha?mascara(mes.folha.toFixed(2)):''}" oninput="atualizarDado(${idx}, 'folha', this.value)" class="!bg-[#09111a] !border-[#1e2a3a]"></td>`;
                    html += `<td class="text-center font-bold bg-[#121c2a] text-[13px] leading-tight" id="out_${idx}_fatorR">0,0%</td>`;
