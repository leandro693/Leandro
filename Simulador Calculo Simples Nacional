                localStorage.removeItem('maradel_tabelas'); location.reload();
            }
        }

        function getFaixa(rbt) {
            if(rbt <= 180000) return {n:1, t:"Até 180 mil"};
            if(rbt <= 360000) return {n:2, t:"De 180 mil a 360 mil"};
            if(rbt <= 720000) return {n:3, t:"De 360 mil a 720 mil"};
            if(rbt <= 1800000) return {n:4, t:"De 720 mil a 1,8 mi"};
            if(rbt <= 3600000) return {n:5, t:"De 1,8 mi a 3,6 mi"};
            return {n:6, t:"De 3,6 mi a 4,8 mi"};
        }

        function mascaraData(i) {
            let v = i.value.replace(/\D/g, "");
            if (v.length > 2) v = v.substring(0, 2) + "/" + v.substring(2, 6);
            i.value = v;
        }

        function mascara(v) {
            v = v.toString().replace(/\D/g, "");
            v = (v / 100).toFixed(2).replace(".", ",");
            v = v.replace(/(\d)(?=(\d{3})+(?!\d))/g, "$1.");
            return v;
        }

        function pM(v) { return parseFloat(v.toString().replace(/\./g, "").replace(",", ".")) || 0; }

        function diffMeses(d1, d2) {
            let months = (d2.getFullYear() - d1.getFullYear()) * 12;
            months -= d1.getMonth();
            months += d2.getMonth();
            return months;
        }

        function getD(str) {
            if(!str || !str.includes('/')) return null;
            const [m, a] = str.split('/');
            return new Date(a, m-1, 1);
        }

        function preencherEIniciar() {
            const dAb = document.getElementById('dataAb').value;
            if(dAb.length === 7 && document.getElementById('dataSim').value === "") {
                const dataAtual = new Date();
                document.getElementById('dataSim').value = `${dataAtual.getMonth()+1}`.padStart(2,'0') + '/' + dataAtual.getFullYear();
            }
            iniciarSimulador();
        }

        function iniciarSimulador() {
            const dataAbStr = document.getElementById('dataAb').value;
            const dataSimStr = document.getElementById('dataSim').value;
            if(!dataSimStr || dataSimStr.length < 7) return;

            const dataAb = getD(dataAbStr);
            const dataSim = getD(dataSimStr);
            let m = dataSim.getMonth() + 1;
            let a = dataSim.getFullYear();

            precisaHistorico = false;
            rbt12Value = 0;
            folha12Value = 0;

            if (dataAb && diffMeses(dataAb, dataSim) > 0) {
                precisaHistorico = true;
                dFimHist = new Date(dataSim); dFimHist.setMonth(dFimHist.getMonth() - 1);
                dIniHist = new Date(dFimHist); dIniHist.setMonth(dIniHist.getMonth() - 11);
            }

            dados = [];
            let chavesAnexos = Object.keys(NOMES_ANEXOS);
            for(let i=0; i<12; i++){
                let mesObj = { mes: `${(m-1+i)%12+1}`.padStart(2,'0') + '/' + (a + Math.floor((m-1+i)/12)), folha: 0, exp: false };
                chavesAnexos.forEach(k => mesObj['v'+k] = 0);
                dados.push(mesObj);
            }

            renderTableStructure();
        }

        function tentarToggleAnexo(id) {
            const cb = document.getElementById('chkAnexo'+id);
            if (!cb.checked) {
                const temDados = dados.some(d => (d['v'+id] || 0) > 0);
                if (temDados) {
                    anexoPendenteRemocao = id;
                    document.getElementById('modalText').innerHTML = `Deseja remover a coluna do <b>${NOMES_ANEXOS[id]}</b>?<br>Os valores já preenchidos serão perdidos.`;
                    document.getElementById('modalConfirm').classList.remove('hidden');
                } else {
                    confirmarRemocaoAnexoDir(id);
                }
            } else {
                if(!anexosSel.includes(id)) anexosSel.push(id);
                anexosSel.sort();
                renderTableStructure();
            }
        }

        function confirmarRemocaoAnexo() {
            if(anexoPendenteRemocao) confirmarRemocaoAnexoDir(anexoPendenteRemocao);
            fecharModal();
        }

        function confirmarRemocaoAnexoDir(id) {
            anexosSel = anexosSel.filter(x => x !== id);
            dados.forEach(d => d['v'+id] = 0);
            renderTableStructure();
        }

        function fecharModal() {
            if(anexoPendenteRemocao && anexosSel.includes(anexoPendenteRemocao)) document.getElementById('chkAnexo'+anexoPendenteRemocao).checked = true;
            document.getElementById('modalConfirm').classList.add('hidden');
            anexoPendenteRemocao = null;
        }

